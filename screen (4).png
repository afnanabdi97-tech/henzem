                    "background": "#f8f9ff",
                    "primary-fixed": "#a6f2d1",
                    "antique-base": "#FAEBD7",
                    "danger-clay": "#FF5335",
                    "amber-accent": "#F59E0B",
                    "on-surface-variant": "#3f4944",
                    "on-error-container": "#93000a",
